# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# generated native folders
# Anchored with a leading slash, so these match ONLY the prebuild output at the
# repo root and not, say, modules/ble-mesh/android/ — which is real source.
/ios
/android

# Native build output.
# The local Expo modules keep their real source at modules/<name>/android/ and
# modules/<name>/ios/, so those must stay tracked — but Gradle drops compiled
# .class files, incremental-compilation caches (*.tab, *.bin, lookups/) and
# manifest-merger reports into a build/ dir inside them. That is several hundred
# files of pure noise, and it is what produced a 502-file diff.
**/build/
**/.gradle/
**/.cxx/
**/DerivedData/

# Build artefacts. Large, binary, and regenerated by any build.
*.apk
*.aab
*.ipa
*.xcarchive

# CocoaPods
Pods/
*.xcworkspace

# Test and coverage output
coverage/
*.log

# Local iOS signing (personal Apple team id — never commit)
signing.local.json
